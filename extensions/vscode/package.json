{
  "name": "agentboard",
  "displayName": "AgentBoard",
  "description": "Kanban board for AI coding agents",
  "version": "0.1.0",
  "publisher": "ayan-de",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onCommand:agentboard.helloWorld",
    "onCommand:agentboard.open",
    "onView:agentboard.kanban"
  ],
  "contributes": {
    "commands": [
      {
        "command": "agentboard.helloWorld",
        "title": "Hello World"
      },
      {
        "command": "agentboard.open",
        "title": "Open AgentBoard"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "agentboard-panel",
          "title": "AgentBoard",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "agentboard-panel": [
        {
          "type": "webview",
          "id": "agentboard.kanban",
          "name": "AgentBoard"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.75.0",
    "@vscode/test-electron": "^2.3.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "react-icons": "^5.6.0"
  }
}
